# MarketStack MCP - Environment Variables
# ----------------------------------------
# Copy this file to .env and fill in your values:  cp .env.template .env

# Get your free API key at https://marketstack.com/ and set it here
MARKETSTACK_API_KEY=your_api_key_here

# Ollama model tag — must match exactly what 'ollama list' shows for the
# model you want to use.
OLLAMA_MODEL=gemma4:e4b

# Watchlist — comma-separated symbols the server tracks and analyzes.
# Leave this commented out to use the built-in default (VTI, VOO).
# Uncomment and edit to track different / additional assets, e.g.:
#   WATCHLIST=VTI,VOO,QQQ,BND,AAPL
# WATCHLIST=VTI,VOO
